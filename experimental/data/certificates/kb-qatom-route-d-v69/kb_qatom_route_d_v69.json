    "OPEN": {
      "name": "OPEN_no_GP_multipad_at_deployed",
      "statement": "No disjoint A,B subset {0..n'-1}, |A|=|B|=e, with sum_{a in A} omega^{a k} = sum_{b in B} omega^{b k} for all k=1..e-1 (deployed omega of order n).",
      "status": "OPEN"
    },
    "deployed_not_threshold": {
      "name": "deployed_exceeds_2e_threshold",
      "proof": [
        "2e=134944, n'=1183520, floor(n'/e)=17."
      ],
      "statement": "Deployed n'=1183520 >= 2e=134944 (ratio n'/e=17.5409); threshold injectivity (3) does not apply; GP multipad ban still open.",
      "status": "PROVED"
    },
    "disjoint": {
      "name": "free1_multipads_are_disjoint",
      "proof": [
        "Same free-1 monic high => f_U - f_V = delta (nonzero constant).",
        "If r in U cap V then f_U(r)=f_V(r)=0 => delta=0, contradiction.",
        "|U|=|V|=e and disjoint => |cup|=2e."
      ],
      "statement": "Any free-1 multipad pair U!=V satisfies U cap V = empty and |U cup V| = 2e.",
      "status": "PROVED"
    },
    "gp_index": {
      "name": "GP_power_sum_index_form",
      "proof": [
        "Direct expansion p_k = sum_{a in A} (omega^a)^k = sum_a omega^{a k}.",
        "v56: free-1 monic high <=> power sums in char > e."
      ],
      "statement": "For U={omega^a : a in A}, p_k(U)=sum_{a in A} omega^{a k}; power-sum free-1 multipad <=> matching DFT moments k=1..e-1 on index sets A,B of size e (disjoint by (1)).",
      "status": "PROVED"
    },
    "same_derivative": {
      "name": "multipad_same_derivative",
      "proof": [
        "f_U - f_V constant => derivatives equal."
      ],
      "statement": "Free-1 multipad monic polys satisfy f_U' = f_V' (identical derivatives).",
      "status": "PROVED"
    },
    "threshold_inj": {
      "name": "injectivity_when_t_lt_2e",
      "proof": [
        "Multipad needs two disjoint e-sets => at least 2e ambient points.",
        "t < 2e forbids multipads => injective => v68 close."
      ],
      "statement": "If t < 2e then free-1 high is injective on e-subsets of any t-set, hence coll=0 and |T|=0.",
      "status": "PROVED"
    }
  },
