  "lemmas": {
    "G_vanishing": {
      "name": "multipad_index_poly_vanishes_at_omega_powers",
      "proof": [
        "G(omega^k)=sum_A omega^{a k}-sum_B omega^{b k}=p_k(U)-p_k(V).",
        "k=0: |A|-|B|=0; k=1..e-1: free-1/power-sum multipad match (char>e)."
      ],
      "statement": "For multipad index sets A,B: G(X)=sum_A X^a - sum_B X^b satisfies G(omega^k)=0 in F_p for all k=0..e-1.",
      "status": "PROVED"
    },
    "OPEN": {
      "name": "OPEN_no_sparse_G_equals_Pe_H_deployed",
      "statement": "No G = sum_A X^a - sum_B X^b with A,B disjoint e-subsets of {0..n'-1} (n'=1183520, e=67472) equal to P_e * H for H in F_p[X].",
      "status": "OPEN"
    },
    "Pe_divides": {
      "name": "P_e_divides_G",
      "proof": [
        "omega has order n >= e => {1,omega,...,omega^{e-1}} distinct in F_p.",
        "G vanishes at each => each (X-omega^k)|G; product monic of deg e divides G.",
        "A!=B => G not zero poly => deg G >= e."
      ],
      "statement": "P_e(X)=prod_{k=0}^{e-1}(X-omega^k) divides G in F_p[X]; hence deg G >= e (G not ~ 0).",
      "status": "PROVED"
    },
    "deg_window": {
      "name": "multipad_G_degree_window",
      "proof": [
        "Support of A cup B in {0..t-1} => deg <= t-1.",
        "Disjoint |A|=|B|=e => 2e nonzero coeffs +/-1 (v69).",
        "Division by P_e of deg e gives deg H = deg G - e."
      ],
      "statement": "e <= deg G <= t-1 and G = P_e H with 0 <= deg H <= t-1-e; G has exactly 2e nonzero coefficients in {-1,+1}.",
      "status": "PROVED"
    },
