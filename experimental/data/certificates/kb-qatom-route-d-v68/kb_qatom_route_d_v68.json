    "ee_identity": {
      "name": "free1_S_equals_elementary_symmetric_of_u",
      "proof": [
        "Expand prod_i (1 + z u_i) = sum_k z^k e_k(u).",
        "Coefficient of z^e is sum_{|I|=e} prod_{i in I} u_i = sum_{|I|=e} psi(sum_{i in I} Q(v_i))."
      ],
      "statement": "For Q of deg <= e-1: S = sum_{|U|=e} psi(sum_{x in U} Q(x)) = e_e(u) with u_i = psi(Q(v_i)).",
      "status": "PROVED"
    },
    "injectivity_close": {
      "name": "injectivity_implies_T_zero",
      "proof": [
        "Injective => m_h in {0,1} => coll = sum m(m-1) = 0.",
        "v57: |T| <= coll/2 = 0."
      ],
      "statement": "If free-1 high is injective on e-subsets of I_t, then coll=0 and |T|<=coll/2=0 <= H2.",
      "status": "PROVED"
    },
    "multipad_poly": {
      "name": "multipad_monic_polynomial_criterion",
      "proof": [
        "Free-1 monic high = coeffs of X^{e-1},...,X^1 (or equiv e1..e_{e-1}).",
        "Same high => f_U - f_V is constant delta.",
        "delta=0 => f_U=f_V => same root set (char 0 / distinct roots)."
      ],
      "statement": "U!=V are free-1 multipads iff monic f_U, f_V differ by a nonzero constant delta (agree in degrees 1..e-1).",
      "status": "PROVED"
    },
    "pigeonhole_room": {
