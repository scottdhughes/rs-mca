      "status": "PROVED"
    },
    "OPEN": {
      "name": "OPEN_overflow_deployed",
      "statement": "(1) Prove N_over \u2264 e\u00b7p (or |H_over|\u2264H_OVER_ENUM_MAX) at deployed A_SP, or ambient |H|\u2264K_cap so H_over=\u2205.\n(2) Or accept hybrid/TARGET multi-cell accounting outside single A_SP\u2264t\u00b7p.\n(3) Or find a local overflow mark of size e\u00b7p (toys negative so far).",
      "status": "OPEN"
    },
