  "impact_on_program": {
    "next": "Bound N_ord or |H| at deployed free_core; Type D residual uses H2",
    "overflow": "|H|>K_cap blocks multi-tier one-cell sides, but card A_SP\u2264t\u00b7p survives until N_ord>e\u00b7p (or |H|>H2 under M_pad\u22642)",
    "preferred_attack": "Prove N_ord\u2264e\u00b7p or |H|\u2264H2=77291948627 (much weaker than K_cap=2170)"
  },
  "lemmas": {
    "Kcap_suff": {
      "name": "Kcap_sufficient_for_both_gates",
      "proof": [
        "Arithmetic + lemmas above."
      ],
      "statement": "|H|\u2264K_cap=2170 \u21d2 N_side\u22642018100 \u226a e\u00b7p \u21d2 N_ord\u226417\u00b7N_side \u226a e\u00b7p \u21d2 |A_SP|\u2264t\u00b7p (Gate B), and multi-tier sides fit (Gate A).",
      "status": "PROVED"
    },
    "N_ord_mpad": {
      "name": "N_ord_le_Mpad_N_side",
      "proof": [
        "v20: N_ord(z) \u2264 M_pad(z)\u00b7N_side(z); global same with max M_pad."
      ],
      "statement": "N_ord \u2264 M_pad \u00b7 N_side (v20 multipad calculus).",
      "status": "PROVED"
    },
    "N_side": {
      "name": "N_side_le_H_times_family",
      "proof": [
        "Per high: |F_H| \u2264 \u230an/e\u230b (v25); ordered pairs \u2264 f(f\u22121).",
        "Sum over highs."
      ],
      "statement": "N_side := # unique free-1 CS ordered pairs (U,V) (distinct c0, same high) satisfies N_side \u2264 |H| \u00b7 \u230an/e\u230b \u00b7 (\u230an/e\u230b\u22121) = 930|H|.",
      "status": "PROVED"
    },
    "OPEN": {
      "name": "OPEN_N_ord_or_H_weak",
      "statement": "(1) Prove N_ord \u2264 e\u00b7p at deployed A_SP (strongest card close), or\n(2) Prove |H| \u2264 H2=77291948627 (M_pad\u22642 residual) / H17 / H1, or\n(3) Prove |H| \u2264 K_cap=2170 (closes both gates).\nAmbient free-1 can exceed K_cap (v40); card still open at weak gates.",
      "status": "OPEN"
    },
    "card_bridge": {
      "name": "A_SP_le_N_ord_card_bridge",
      "proof": [
        "v17: |A_SP| \u2264 N_ord = sum_{k\u22652} k(k\u22121) over multi top-seam cliques.",
        "t = e deployed \u21d2 t\u00b7p = e\u00b7p."
      ],
      "statement": "|A_SP| \u2264 N_ord (v17). Therefore N_ord \u2264 e\u00b7p = t\u00b7p \u21d2 |A_SP| \u2264 t\u00b7p. This is pure cardinality \u2014 no multi-tier, no high tag.",
      "status": "PROVED"
    },
    "decouple": {
      "name": "decouple_Kcap_from_card",
      "proof": [
        "v41: R\u00b731\u00b731\u2264e forces R\u226470 and |H|\u2264K_cap for (\u03c4,local,\u03b9,\u03b4).",
        "This file: card gates H1/H2/H17."
      ],
      "statement": "Gate A (multi-tier (\u03ba,\u03b9,\u03b4) in one e\u00b7p) needs |H|\u2264K_cap (v41). Gate B (card |A_SP|\u2264t\u00b7p) needs only N_ord\u2264e\u00b7p, which allows |H| up to H2\u224877291948627 under M_pad\u22642. Overflow |H|>K_cap blocks Gate A, not necessarily Gate B.",
      "status": "PROVED"
    },
    "mu_all": {
      "name": "joint_side_enum_ep",
      "proof": [
        "Same mixed radix as \u03bc_enum / \u03bc_over (v38\u2013v39)."
      ],
      "statement": "Order all unique free-1 CS pairs lex; \u03bc_all=(i mod e, \u230ai/e\u230b) injective. If N_side \u2264 e\u00b7p then \u03bc_all : pairs \u2192 [e]\u00d7F_p. Pays core and overflow together \u2014 no H_core split required for constructive side payment.",
      "status": "PROVED"
    },
    "weak_H": {
      "deployed": {
        "H1": 154583897255,
        "H17": 9093170426,
        "H2": 77291948627,
        "K_cap": 2170
      },
      "name": "weak_high_gates_for_card",
      "proof": [
        "N_ord \u2264 M_pad \u00b7 930 \u00b7 |H| \u2264 e\u00b7p \u21d4 |H| \u2264 e\u00b7p/(M_pad\u00b7930).",
        "Type D residual after SR has M_pad\u22642 (v35) \u21d2 H2 gate applies to residual."
      ],
      "statement": "Under N_side \u2264 930|H| and N_ord \u2264 M_pad\u00b7N_side:\n  M_pad\u22641 and |H|\u2264H1=154583897255 \u21d2 N_ord\u2264e\u00b7p \u21d2 |A_SP|\u2264t\u00b7p\n  M_pad\u22642 and |H|\u2264H2=77291948627 \u21d2 same\n  M_pad\u226417 and |H|\u2264H17=9093170426 \u21d2 same\nAll H1,H2,H17 \u226b K_cap=2170.",
      "status": "PROVED"
    }
  },
