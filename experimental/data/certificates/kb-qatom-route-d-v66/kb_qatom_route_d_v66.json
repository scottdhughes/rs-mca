  "lemmas": {
    "D_mass": {
      "name": "Dirichlet_kernel_mass",
      "proof": [
        "|D(m)| = |sin(pi t m/n)/sin(pi m/n)| <= 1/|sin(pi m/n)|.",
        "|sin(pi m/n)| >= 2 d(m)/n with d(m)=min(m,n-m) on 1..n-1 (sin(pi x) >= 2x on [0,1/2]).",
        "Thus |D(m)| <= n/(2 d(m)).",
        "sum_{m!=0}|D| <= 2 sum_{d=1}^{floor(n/2)} n/(2d) = n H_{floor(n/2)}.",
        "H_k <= 1 + ln k <= 1 + ln n."
      ],
      "statement": "sum_{m=1}^{n-1} |D(m)| <= n (1 + ln n) for 1<=t<=n.",
      "status": "PROVED"
    },
    "J": {
      "name": "mixed_Gauss_J_bound",
      "proof": [
        "m=0: full subgroup sum (v65).",
        "m!=0: J=sum_{x in H} psi(alpha x) eta(x), eta nontrivial on H.",
        "1_H = (n/(p-1)) sum_{rho|H=1} rho; expand; all resulting multiplicative characters are nontrivial (eta nontrivial on H), each Gauss sum has magnitude sqrt(p); triangle with (n/(p-1))*((p-1)/n)*sqrt(p)=sqrt(p)."
      ],
      "statement": "For alpha!=0: |J(0,alpha)|<=sqrt(p)+1; |J(m,alpha)|<=sqrt(p) for m not equiv 0 mod n.",
      "status": "PROVED"
    },
    "OPEN": {
      "name": "OPEN_soft_B_free1_S",
      "statement": "Prove max|S(lambda)| <= B_*~393172 for free-1 monic highs of e-sets on the deployed GP arc (linear G bound is not enough alone).",
      "status": "OPEN"
    },
