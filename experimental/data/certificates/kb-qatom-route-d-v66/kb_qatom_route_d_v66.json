      "status": "PROVED"
    },
    "dirichlet": {
      "name": "incomplete_GP_Dirichlet_expansion",
      "proof": [
        "Fourier expansion of 1_{[0,t)} on Z/nZ.",
        "Substitute into sum_{k<t} psi(alpha omega^k)."
      ],
      "statement": "G_t(alpha) = n^{-1} sum_m D(m) J(m,alpha) with D(m)=sum_{j<t} e^{-2 pi i m j / n}, J(m,alpha)=sum_{k<n} psi(alpha omega^k) e^{2 pi i m k / n}.",
      "status": "PROVED"
    },
    "incomplete": {
      "name": "incomplete_GP_G_bound",
      "proof": [
        "|G_t| <= n^{-1}( |D(0)||J(0)| + sum_{m!=0}|D(m)||J(m)| ).",
        "<= n^{-1}( t (sqrt(p)+1) + sqrt(p) sum_{m!=0}|D| ).",
        "<= (t/n)(sqrt(p)+1) + sqrt(p)(1+ln n)."
      ],
      "statement": "For alpha!=0, 1<=t<=n, |G_t(alpha)| <= (t/n)(sqrt(p)+1) + sqrt(p)(1+ln n).",
      "status": "PROVED"
    }
  },
