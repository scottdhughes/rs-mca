    },
    "fc2_through": {
      "applies_deployed": false,
      "deployed_free_core": 846161,
      "deployed_through_pack_if_fc2": 2,
      "name": "free_core_2_through_set_packing",
      "proof": [
        "free_core=2 \u21d2 deg(\u0394)\u22641. If r\u2208C\u2229C' then \u0394=\u03b1(X\u2212r), \u03b1\u22600 \u21d2 M\u2212M' constant \u22600 \u21d2 free-1 CS reduced cores.",
        "v25 packing on ground set D\\(U\u222aV\u222a{r}) of size n\u22122e\u22121 with block size m_c\u22121.",
        "Any two cores in Cores_r share r so reduce as above."
      ],
      "statement": "If free_core=2 and (U,V) is a multipad side key, then for every domain point r the through-set Cores_r has reduced cores that are free-1 CS of size m_c\u22121 (Type D), hence |Cores_r| \u2264 \u230a(n\u22122e\u22121)/(m_c\u22121)\u230b. Deployed this is 2 (if free_core were 2).",
      "status": "PROVED"
    },
