  "lemmas": {
    "OPEN": {
      "name": "OPEN_Winf_and_sharp_S",
      "statement": "Prove W_inf <= sqrt(p t) (or better) for quadratic phases on GP arcs, and/or improve the All bound so that |S| <= sqrt(C) in sparse regime.",
      "status": "OPEN"
    },
    "S_bound": {
      "name": "e3_S_bound_from_Winf",
      "proof": [
        "Combine diagonal identity with All bound."
      ],
      "statement": "|S| <= (1/6)( sqrt(p) W_inf^3 + 3t(t-1) + t ) for l1!=0.",
      "status": "PROVED"
    },
    "all_bound": {
      "name": "e3_all_bound_by_Winf",
      "proof": [
        "All = p^{-1} sum_xi hatH(-xi) hat_mu(xi)^3.",
        "|All| <= p^{-1} W_inf^3 sum_xi |hatH(xi)|.",
        "sum |hatH| <= sqrt(p) sqrt(sum |hatH|^2) = sqrt(p)*p = p^{3/2},",
        "since sum_xi |hatH|^2 = p sum_s |H|^2 = p^2.",
        "Thus |All| <= p^{-1} W_inf^3 p^{3/2} = sqrt(p) W_inf^3."
      ],
      "statement": "|All| <= sqrt(p) * W_inf^3 with W_inf = max |sum_{i<t} psi(A vi^2 + B vi)| over A,B in F_p.",
      "status": "PROVED"
    },
    "diag": {
      "name": "e3_diagonal_identity",
      "proof": [
        "Partition (i,j,k) in [0,t)^3 by equality type of indices.",
        "Distinct values for distinct indices on a GP of length t<=n.",
        "Each unordered triple contributes 3!=6 ordered triples."
      ],
      "statement": "For distinct arc values, All = 6S + 3 D2 + D3, hence |S| <= (1/6)(|All| + 3t(t-1) + t).",
      "status": "PROVED"
    },
    "fourier": {
      "name": "e3_all_triple_fourier_formula",
      "proof": [
        "Phi = (l1/2)s1^2 - l0 s1 - (l1/2)p2 with s1=u+v+w, p2=u^2+v^2+w^2.",
        "psi(Phi)=H(s1) g(u)g(v)g(w), g(x)=psi((-l1/2)x^2).",
        "Sum over arc indices = sum_s H(s) sum_{vi+vj+vk=s} g(vi)g(vj)g(vk)."
      ],
      "statement": "For l1!=0, char!=2: All = sum_s H(s)(mu*mu*mu)(s) with H(s)=psi((l1/2)s^2 - l0 s), mu=sum_i psi((-l1/2)vi^2) delta_vi.",
      "status": "PROVED"
    },
    "high": {
      "name": "e3_monic_high_formulas_char_ne_2",
      "proof": [
        "Expand the cubic; Newton for e2 vs power sums."
      ],
      "statement": "For the product convention (1-uX)(1-vX)(1-wX), h0=-(u+v+w), h1=uv+uw+vw=((u+v+w)^2-(u^2+v^2+w^2))/2 in char != 2.",
      "status": "PROVED"
    }
  },
