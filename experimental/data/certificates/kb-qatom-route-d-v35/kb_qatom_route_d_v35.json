    "card_gate": {
      "name": "high_cardinality_gate_for_Kmax",
      "proof": [
        "Injection into a set of size C requires |domain|\u2264C.",
        "v34 multi-tier capacity = R_max\u00b7\u230an/e\u230b \u2264 K_max."
      ],
      "statement": "Multi-tier FM (v34) injects H_A_SP into a set of size \u22642170 \u2286 [K_max] if and only if |H_A_SP| \u2264 2170. No ambient proof that |H_A_SP|\u22642170 is known; matching-supported H_M always satisfies the gate.",
      "status": "PROVED"
    },
    "matching_highs": {
      "deployed": {
        "fits": true,
        "floor_n_over_e": 31,
        "tier_capacity": 2170
      },
      "ledger_path": "If A_SP side marks only use highs in H_M for a fixed global matching M of sides, high tags fit budget. Toys: pairs with both sides in M are rare \u2014 insufficient alone for full N_ord.",
      "name": "matching_supported_highs_le_n_over_e",
      "proof": [
        "Map U \u21a6 high(U) from M to H_M is surjective onto H_M, so |H_M| \u2264 |M|.",
        "Any matching of e-sets in a domain of size n has |M| \u2264 \u230an/e\u230b.",
        "Within one high, F_H is pairwise disjoint (v25), so a matching may contain several U from one high; that only makes |H_M| smaller."
      ],
      "statement": "Let M be any matching of active free-1 e-sets (pairwise disjoint). Let H_M = {{ high(U) : U \u2208 M }}. Then |H_M| \u2264 |M| \u2264 \u230an/e\u230b. Deployed: |H_M| \u2264 31 \u2264 2170 \u2264 2176.",
      "status": "PROVED"
    },
    "not_star_only": {
      "name": "star_only_residual_not_forced",
      "proof": [
        "v32 non-star census; SR-cell definition."
      ],
      "statement": "Ambient Type S is not star-only (non-star multipads exist). SR-cell pays non-star via some r_* without global common intersection. A residual that is star-only is not forced by ambient geometry alone.",
