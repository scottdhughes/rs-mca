    "sr_cell": {
      "cost_open": "SR-cell mass/injection into e\u00b7p still OPEN (naive (r_*,sidekey) collides).",
      "deployed_type_D_bound": 2,
      "name": "shared_root_first_match_cell_type_D_residual",
      "proof": [
        "Type S \u21d4 t\u22652 \u21d4 exists r with mult(r)\u22652 \u21d4 r_* exists and is paid in SR-cell.",
        "Any multipad not paid by SR-cell has no r with mult\u22652 \u21d4 t=1 \u21d4 Type D.",
        "Type D packing: v28/v29.",
        "Star-only not required: non-star Type S still have some r with mult\u22652."
      ],
      "statement": "Define the shared-root first-match cell (SR-cell): for each Type S multipad side key with core mult t\u22652, set r_* = min{{r : mult(r)\u22652}} and pay that multipad event when domain order reaches r_*. After all SR-cell payments, every remaining multipad has t=1, i.e. is Type D, hence M_pad \u2264 \u230a(n\u22122e)/m_c\u230b (= 2 deployed).",
      "status": "PROVED"
    }
  },
