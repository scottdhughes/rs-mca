  "impact_on_program": {
    "multimate": "Multipads = depth-w power-sum multi-mates + joint complement CS-extension; free_core=1 fiber free (CAS)",
    "next": "Inject residual FS_1(e) into [e], or bound free_core\u226b1 power-sum multi-mates with joint avoid",
