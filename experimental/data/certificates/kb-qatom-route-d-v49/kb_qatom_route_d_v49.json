      "status": "PROVED"
    },
    "prefix_window": {
      "name": "coext_free1_lives_in_index_prefix",
      "proof": [
        "By construction of sorted-index prefix: every index in U is < every index in C, so U \u2286 {0,...,min(C)\u22121}.",
        "Multi-U pencil fixes C and varies U among free-1 mates of a high."
      ],
      "statement": "Under the A_SP prefix split U = e least domain indices of S and C = S\\U: max(U) < min(C). Any multi-U free-1 pencil with core C has every U \u2286 I_t = {0,...,t\u22121}, t = min(C).",
      "status": "PROVED"
    },
