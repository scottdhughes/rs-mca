  "lemmas": {
    "CS": {
      "name": "e3_All_CS_Plancherel",
      "proof": [
        "Cauchy-Schwarz on sum_s (psi(-l0 s) f(s)) G(beta(s)).",
        "beta bijective => sum_s |G(beta(s))|^2 = sum_a |G(a)|^2 = p t."
      ],
      "statement": "For l1!=0: |All| <= sqrt(sum_s |f(s)|^2) * sqrt(p t).",
      "status": "PROVED"
    },
    "OPEN": {
      "name": "OPEN_phased_energy_or_soft_B_deployed",
      "statement": "Bound sum|f|^2 for GP arcs (e=3 method), and/or prove max|S| <= B_* ~ 393172 at deployed (n',e).",
      "status": "OPEN"
    },
    "deployed_Bstar": {
      "name": "deployed_Bstar_arithmetic",
      "numbers": {
        "B_star": 393171.5875467097,
        "H2": 77291948627,
        "log2_C": 373341.4820927906,
        "log2_C2_over_p_em1": -1344154.580361308
      },
      "proof": [
        "log2 binom(n',e) by summing log2((n'-i)/(i+1)).",
        "C^2/p^{e-1} = 2^{log2_term} with log2_term ~ -1.34e6 => ~0.",
        "B_*^2 = 2 H2 - C^2/p^{e-1} = 2 H2 for practical purposes."
      ],
      "statement": "At deployed (n',e,p,H2): log2(C^2/p^{e-1}) ~ -1344154.6 (<<0), so B_* = sqrt(2 H2) ~ 393171.6 suffices for soft-B close.",
      "status": "PROVED"
    },
    "energy_dom": {
      "name": "phased_energy_le_additive_energy",
      "proof": [
        "|f(s)| <= r(s) termwise (unimodular sum).",
        "E_+(S) is the ordered additive energy of S."
      ],
      "statement": "sum |f|^2 <= E_+(S) := sum_s r(s)^2, r(s)=|S cap (s-S)|; hence |All| <= sqrt(E_+(S) p t).",
      "status": "PROVED"
    },
    "level_set": {
      "name": "e3_All_level_set_f_G",
      "proof": [
        "Group (i,j) by s=vi+vj; vi vj = s vi - vi^2.",
        "Inner sum over such x=vi in S with s-x in S is f(s).",
        "Factor G(beta(s)) from the third arc index (v63)."
      ],
      "statement": "All = sum_s psi(-l0 s) f(s) G(-l0+l1 s) with f(s)=sum_{x in S cap (s-S)} psi(l1(s x - x^2)).",
      "status": "PROVED"
    },
    "soft_B": {
      "name": "soft_B_coll_budget",
      "proof": [
        "v58: coll <= C^2/p^{e-1} + B^2.",
        "v57: |T| <= nH <= coll/2.",
        "coll/2 <= H2 <=> coll <= 2 H2."
      ],
      "statement": "If max_{lambda!=0}|S(lambda)| <= B and B^2 + C^2/p^{e-1} <= 2 H2, then coll <= 2 H2 and |T| <= H2 (via v57-v58).",
      "status": "PROVED"
    }
  },
