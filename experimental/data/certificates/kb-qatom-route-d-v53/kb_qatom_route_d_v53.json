  "lemmas": {
    "C_unique": {
      "name": "C_unique_pure_untyped_high",
      "proof": [
        "Lemma untyped_terminal: every untyped pair has core C_*.",
        "All pairs of a pure-untyped high are untyped \u21d2 same C_*."
      ],
      "statement": "Every untyped free-1 CS pair has core C_*. Hence a pure-untyped high (all its free-1 CS pairs untyped) has unique core C_*.",
      "status": "PROVED"
    },
    "N_C_one": {
      "name": "N_C_eq_1_for_pure_untyped",
      "proof": [
        "Every pure-untyped high has core C_* (C_unique).",
        "t=min(C_*)=n'; U's of pure-untyped live in I_{n'}.",
        "H_unt = H_unt(C_*) \u2286 free-1 multipad highs on I_{n'}.",
        "Hence |H_unt| \u2264 H_*^pre(n',e)."
      ],
      "statement": "The set of cores of pure-untyped highs is either empty or {C_*}. In particular N_C \u2264 1, and |H_unt| \u2264 H_*^pre(n',e).",
      "status": "PROVED",
      "upgrade": "v47 had |H_unt|\u2264N_C\u00b7H_*(n',e); now N_C=1 removes the N_C factor."
    },
    "OPEN": {
      "name": "OPEN_Hstar_pre_nprime_le_H2",
      "statement": "Prove H_*^pre(n',e) \u2264 H2=77291948627 for deployed n'=1183520, e=67472. e=2: closed (|H|\u2264p\u2264H2). e>2: open (v48\u2013v52).",
      "status": "OPEN"
    },
    "core_count": {
      "name": "free1_side_key_core_count",
      "proof": [
        "A_SP requires max(U),max(V)<min(C) \u21d2 C\u2286{max(U\u222aV)+1..n\u22121}.",
        "Fiber match automatic (lemma fiber_automatch).",
        "Each such C of size m_c gives a multi-U free-1 pencil pair."
      ],
      "statement": "For free-1 (U,V), the A_SP cores are exactly the m_c-subsets of {max(U\u222aV)+1,\u2026,n\u22121}; count = binom(n\u22121\u2212max(U\u222aV), m_c).",
      "status": "PROVED"
    },
    "fiber_automatch": {
      "name": "free1_fiber_automatch_w_eq_e_minus_1",
      "proof": [
        "e_k(C\u2294U)=\u2211_{i=0}^k e_i(C) e_{k\u2212i}(U).",
        "Difference = \u2211_i e_i(C)(e_{k\u2212i}(U)\u2212e_{k\u2212i}(V)).",
        "For free-1, e_j(U)=e_j(V) for j=1..e\u22121; e_0=1.",
        "Only possible nonzero: j=e term \u21d2 e_{k\u2212e}(C)\u00b7(e_e(U)\u2212e_e(V)).",
        "For k<e this index k\u2212e<0 \u21d2 difference 0.",
        "w=e\u22121 \u21d2 all k=1..w are <e \u21d2 fiber match automatic."
      ],
      "statement": "If free-1 U,V (e_i(U)=e_i(V) for i=1..e\u22121) and C is disjoint from U\u222aV with max(U\u222aV)<min(C), then e_k(C\u2294U)=e_k(C\u2294V) for k=1..w, where e=w+1 so w=e\u22121.",
      "status": "PROVED"
    },
    "untyped_terminal": {
      "name": "untyped_iff_terminal_core_C_star",
      "proof": [
        "binom(N,m_c)=1 with m_c\u22651 \u21d4 N=m_c.",
        "N=n\u22121\u2212max(U\u222aV)=m_c \u21d4 max=n\u2212m_c\u22121=n'\u22121.",
        "Upper interval {n'\u2026n\u22121} has length m_c \u21d2 unique C=C_*."
      ],
      "statement": "Untyped \u21d4 binom(n\u22121\u2212max(U\u222aV),m_c)=1 \u21d4 max(U\u222aV)=n'\u22121 with n'=n\u2212m_c, and the unique core is C_*={n',\u2026,n\u22121}. Deployed n'=1183520, |C_*|=m_c=913632.",
      "status": "PROVED"
    }
  },
