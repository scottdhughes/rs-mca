  "E_3": "sum_k (mu_k-2) over cosets with mu_k>=3",
  "K_3": "#{cosets with mu_k>=3} (the proof-program's own K)",
  "K_2": "#{cosets with mu_k>=2} (the sigma-calculus K)",
