  "lemmas": {
    "H_core_packing": {
      "name": "H_core_packing_Kcap",
      "proof": [
        "v34 multi-tier: \u2264\u230an/e\u230b matched highs per tier (disjoint U_rep).",
        "R_max=70 tiers \u21d2 |H_core|\u22642170."
      ],
      "statement": "|H_core| \u2264 R_max\u00b7\u230an/e\u230b = 70\u00b731 = 2170. High gate for ledger payment \u2014 from packing, not ambient L.",
      "status": "PROVED"
    },
    "L_rep": {
      "deployed": {
        "K_cap": 2170,
        "L_rep_gate": 70,
        "R_max": 70
      },
      "name": "matched_representative_load_L_rep_le_Rmax",
      "proof": [
        "Tier \u03c4: free := {0..n\u22121}. Matching claims U_rep \u2286 free; free -= U_rep.",
        "Later claims in the same tier cannot reuse any point of U_rep.",
        "Therefore \u22641 matched high per tier has r\u2208U_rep.",
        "R_max tiers \u21d2 L_rep(r) \u2264 70.",
        "WARNING: this is representative incidence, NOT full-cover load. Full cover(H)=\u22c3 F_H can place r in a mate V\u2260U_rep, so L_cover_core(r) can exceed R_max (toys bank this)."
      ],
      "statement": "Run multi-tier first-match with R=R_max=70 tiers. Let H_core be highs matched in some tier < R_max, each with representative e-set U_rep(H). For each domain point r and tier \u03c4, at most one matched high in that tier has r\u2208U_rep (U_rep leaves the free set). Hence L_rep(r) := #{H\u2208H_core: r\u2208U_rep(H)} \u2264 R_max = 70.",
      "status": "PROVED"
    },
    "OPEN": {
      "name": "OPEN_overflow_when_ambient_H_huge",
      "statement": "H_core is paid (L_core\u226470, |H_core|\u22642170). Overflow highs / pairs still need \u03bc_over with N_over\u2264e\u00b7p or another residual cell. Ambient |H| and ambient L are not bounded by 70.",
      "status": "OPEN"
    },
    "ambient_refute": {
      "consequence": "v38 ambient L\u226470 gate is FALSE as a general free-1 load claim. The surviving L\u226470 statement is the matched-ledger L_core (lemma above).",
