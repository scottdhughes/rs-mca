  "lemmas": {
    "OPEN": {
      "name": "OPEN_no_cancelled_multiple_supp_2e_deployed",
      "statement": "No H gives supp(P_e H)=2e with multipad sign pattern on {0..n'-1} at e=67472, n'=1183520.",
      "status": "OPEN"
    },
    "full_support": {
      "name": "Pe_full_support",
      "proof": [
        "P_e = sum_{j=0}^e (-1)^{e-j} e_{e-j} X^j.",
        "e_m != 0 for all m=0..e by nonvanishing lemma."
      ],
      "statement": "P_e(X)=prod_{k=0}^{e-1}(X-omega^k) has all e+1 coefficients nonzero whenever 1<=e<ord(omega).",
      "status": "PROVED"
    },
    "multipad_constraint": {
      "name": "multipad_requires_cancelled_multiple",
      "proof": [
        "v69: multipads disjoint => supp(G)=2e.",
        "v70: G=P_e H.",
        "Full support P_e: constant H => G is scalar * P_e => supp=e+1.",
        "e>=2 => e+1 < 2e => H nonconstant (deg H >= 1)."
      ],
      "statement": "Any free-1 multipad G=P_e H has supp(G)=2e > e+1=supp(P_e) for e>=2, hence deg H >= 1 and G is a cancelled proper multiple of P_e.",
      "status": "PROVED"
    },
    "nonvanishing": {
      "name": "gaussian_binomial_nonzero_when_e_lt_ord",
      "proof": [
        "binom(e,j)_omega = prod_{i=0}^{j-1} (omega^{e-i}-1)/(omega^{i+1}-1).",
        "For 1<=m<=e<n: n does not divide m => omega^m != 1.",
        "All factors nonzero (and invertible) in F_p.",
        "e_j = omega^{j(j-1)/2} * binom(e,j)_omega with omega power nonzero."
      ],
      "statement": "If ord(omega)=n and 1<=e<n then binom(e,j)_omega != 0 in F_p for all 0<=j<=e, hence all e_j != 0.",
      "status": "PROVED"
    },
    "qbinomial": {
      "name": "Pe_coeffs_via_gaussian_binomial",
      "proof": [
        "Standard q-identity for elementary symmetric means of a geometric progression 1, q, ..., q^{e-1} at q=omega (see e.g. q-binomial theorem).",
        "Verified against direct expansion of P_e on toys."
      ],
      "statement": "For ord(omega)=n and 1<=e<n: e_j(1,omega,...,omega^{e-1}) = omega^{j(j-1)/2} * binom(e,j)_omega with the usual Gaussian product.",
      "status": "PROVED"
    }
  },
