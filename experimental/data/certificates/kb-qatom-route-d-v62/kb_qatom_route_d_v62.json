  "lemmas": {
    "All_refined": {
      "name": "e3_All_le_sqrtp_t_Winf",
      "proof": [
        "All = p^{-1} sum_xi hatH(-xi) hat_mu(xi)^3 (v60).",
        "|hatH|=sqrt(p) => |All| <= p^{-1/2} sum |hat_mu|^3.",
        "sum |hat_mu|^3 <= W_inf sum |hat_mu|^2 = W_inf * p t.",
        "Thus |All| <= p^{-1/2} W_inf p t = sqrt(p) t W_inf.",
        "v61: W_inf <= sqrt(p t) => |All| <= p t^{3/2}."
      ],
      "statement": "For l1!=0: |All| <= sqrt(p) * t * W_inf <= p * t^{3/2}.",
      "status": "PROVED"
    },
    "OPEN": {
      "name": "OPEN_oscillatory_hat_mu_cubed",
      "statement": "Bound |sum_xi hatH(-xi) hat_mu(xi)^3| with phase cancellation (beyond sum |hat_mu|^3) for GP-arc free-1 highs; reach |S|<=sqrt(C).",
      "status": "OPEN"
    },
    "S_refined": {
      "name": "e3_S_refined_envelope",
      "proof": [
        "v60 diagonal identity + refined All bound."
      ],
      "statement": "|S| <= (1/6)( sqrt(p) t W_inf + 3t(t-1)+t ) <= (1/6)( p t^{3/2} + 3t(t-1)+t ).",
      "status": "PROVED"
    },
    "gauss_flat": {
      "name": "quadratic_Fourier_flat_Gauss",
      "proof": [
        "Complete the square: a s^2 + (b+xi)s = a(s + (b+xi)/(2a))^2 - disc/(4a).",
        "Translate s; remaining sum is the standard Gauss sum G(a) with |G(a)|=sqrt(p)."
      ],
      "statement": "For a!=0, H(s)=psi(a s^2 + b s) has |hatH(xi)|=sqrt(p) for all xi.",
      "status": "PROVED"
    },
    "still_weak": {
      "name": "e3_refined_envelope_still_weak",
      "proof": [
        "sqrt(C) ~ t^{3/2}/sqrt(6); bound ~ p t^{3/2}/6 => ratio ~ p/sqrt(6).",
        "Old envelope ~ p^2 t^{3/2}/6; ratio old/new ~ p when W_inf~sqrt(pt)."
      ],
      "statement": "Refined envelope / sqrt(C) ~ p * sqrt(6) -> infinity; still cannot force v58 sqrt-cancel. Improvement over v61 is factor ~ sqrt(p/t).",
      "status": "PROVED"
    }
  },
