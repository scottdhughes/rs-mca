  "lemmas": {
    "OPEN": {
      "name": "OPEN_bound_coll_or_T_in_sparse_regime",
      "statement": "Bound coll (or |T|) by << p^(e-1) in the sparse GP regime, enough that |T|<=H2=77291948627 at deployed (n',e)=(1183520,67472). Terminal injectivity alone does not beat p^(e-1).",
      "status": "OPEN"
    },
    "collision": {
      "name": "collision_vs_nH_and_T",
      "proof": [
        "For each multipad high with fibre size m>=2, contribute m(m-1)>=2 to coll and 1 to nH \u21d2 nH <= coll/2.",
        "Each multipad high has <=1 terminal member (share-root) \u21d2 |T| <= nH."
      ],
      "statement": "Let coll = #{(U,V): U\u2260V, high(U)=high(V)} (ordered). Then nH <= coll/2 and |T| <= nH <= coll/2.",
      "status": "PROVED"
    },
    "partners": {
      "name": "partner_packing_and_pair_injection",
      "proof": [
        "Terminal partner of V: the unique terminal e-set with high(V), if it exists and free-1-matches (uniqueness from terminal injectivity).",
        "Partners of U: other members of F_{high(U)}, pairwise disjoint (v25 / share-root lemma), all in I_t \\ U \u21d2 <= floor((t-e)/e)=floor(t/e)-1.",
        "Map (U,V)\u21a6V is injective on free-1 term/nonterm pairs: V determines high, hence at most one terminal U."
      ],
      "statement": "Each non-terminal e-set has <=1 free-1 terminal partner. Each terminal e-set has <= floor(t/e)-1 free-1 partners. Free-1 pairs (U_term, V_nonterm) inject into non-terminal e-sets, so their count is <= C(t-1,e), and |T| <= that count.",
      "status": "PROVED"
    },
    "share_root": {
      "name": "same_high_share_root_implies_equal_sets",
      "proof": [
        "Let r \u2208 U\u2229V. High a and root r fix \u03b2=\u03c6_a(r).",
        "Unique monic f_\u03b2 of degree e with high a and constant \u03b2.",
        "U and V are both full root sets of f_\u03b2 \u21d2 U=V."
      ],
      "statement": "If two free-1 e-sets U,V have the same monic high a and U\u2229V\u2260\u2205, then U=V.",
      "status": "PROVED"
    },
    "terminal_inj": {
      "name": "terminal_high_map_injective",
      "proof": [
        "Any two terminal e-sets share the terminal root \u03c9^{t-1} (as field values: same domain point).",
        "Same high + shared root \u21d2 equal sets (previous lemma).",
        "Hence distinct terminal e-sets have distinct highs."
      ],
      "statement": "On {e-sets U \u2286 I_t : t-1 \u2208 U}, the monic-high map is injective. In particular |T| <= C(t-1,e-1) with distinct highs for every terminal e-set.",
      "status": "PROVED"
    }
  },
