  "lemmas": {
    "OPEN": {
      "name": "OPEN_terminal_partner_count_le_H2",
      "statement": "Bound |T| \u2264 H2=77291948627 for deployed n'=1183520, e=67472 (free-1 partners of e-sets through the terminal index on a length-n' roots-of-unity arc), or close residual via |R2|\u2264e\u00b7p.",
      "status": "OPEN"
    },
    "inject_T": {
      "name": "H_unt_injects_into_terminal_partner_sets",
      "proof": [
        "Star theorem: U_* unique for each pure-untyped H.",
        "U_* has \u22651 free-1 partner (multipad) \u21d2 U_* \u2208 T.",
        "Different highs \u21d2 different U_* (high determined by U_*; same U_* \u21d2 same high).",
        "T \u2286 {e-sets through n'\u22121} \u21d2 |T| \u2264 C(n'\u22121, e\u22121)."
      ],
      "statement": "The map H \u21a6 U_*(H) injects H_unt into T = {U \u2286 I_{n'} : |U|=e, n'\u22121\u2208U, U has a free-1 partner in I_{n'}}. Thus |H_unt| = |T| \u2264 binom(n'\u22121, e\u22121).",
      "status": "PROVED"
    },
    "marked_U2e": {
      "deployed_note": "Both C(n'-1,2e-1) and C(n'-1,e-1) \u226b H2=77291948627; not yet an H2 close.",
      "name": "marked_U2e_bound",
      "proof": [
        "Each pure-untyped H has free-1 pair (U_*,V) with n'\u22121\u2208U_*\u222aV.",
        "W=U_*\u222aV has size 2e and contains n'\u22121.",
        "U2e: free-1 bip of W unique \u21d2 H \u21a6 W injective among such highs.",
        "Number of 2e-sets through n'\u22121 is C(n'\u22121, 2e\u22121)."
      ],
      "statement": "|H_unt| \u2264 binom(n'\u22121, 2e\u22121). Deployed ratio C(n',2e)/C(n'\u22121,2e\u22121) = n'/(2e) \u2248 8.770.",
      "status": "PROVED",
      "values": {
        "H2": 77291948627,
        "ratio_plain_over_marked": 8.770452928622243
      }
    },
    "pack_k": {
      "evidence": "toy_suite.pack_rows",
      "name": "pack_k_alone_not_H2",
      "statement": "There is no bound H_*^pre(t,e) \u2264 f(k) with k=\u230at/e\u230b that yields H2 at k=17 for general e: already e=3,k=17 can have nH ~ p\u00b2 \u226b H2 (H2/e ~ p/1860 for scale).",
      "status": "REFUTED_AS_H2_STRATEGY"
    },
    "star": {
      "name": "pure_untyped_star_at_terminal",
      "proof": [
        "v53: every untyped pair (U,V) has max(U\u222aV)=n'\u22121, hence n'\u22121\u2208U\u222aV.",
        "v25: F_H pairwise disjoint \u21d2 at most one member of F_H contains n'\u22121.",
        "Pure-untyped \u21d2 \u22651 untyped pair \u21d2 that unique U_* exists.",
        "Any untyped pair must include n'\u22121 \u21d2 must include U_*.",
        "Hence all untyped pairs are stars at U_*; Rest = other free-1 partners of U_* in F_H \u2286 I_{n'}."
      ],
      "statement": "Let H be pure-untyped. Then there is a unique U_* \u2208 F_H with n'\u22121 \u2208 U_*, every untyped free-1 CS pair of H is of the form (U_*, V) with V \u2208 F_H \\ {U_*}, and Rest = F_H \\ {U_*} are free-1 partners of U_* inside I_{n'}.",
      "status": "PROVED"
    }
  },
