    "R2_D": {
      "name": "R2_D_le_2_n_mpad_D",
      "proof": [
        "Side key determines (high,c0U,c0V) uniquely \u21d2 unique ordered pair of root sets with those free-1 constants (v20 \u03c6)."
      ],
      "statement": "Each Type D multipad side key (high,c0U,c0V) is one ordered free-1 pair. At most one reverse key (high,c0V,c0U). Hence |R2_D| \u2264 2 \u00b7 n_mpad_D where n_mpad_D counts Type D multipad side keys with high\u2209H_M (or ambient Type D keys if restricted).",
      "status": "PROVED"
    },
    "R2_family": {
      "name": "R2_le_930_HR2",
      "proof": [
        "Each residual high has |F_H|\u2264\u230an/e\u230b active free-1 U's (v25).",
        "Ordered free-1 pairs within high \u2264 f(f\u22121).",
        "R2 pairs are a subset of those for highs in H_R2."
      ],
      "statement": "|R2| \u2264 |H_R2| \u00b7 \u230an/e\u230b \u00b7 (\u230an/e\u230b\u22121) = 930|H_R2|.",
      "status": "PROVED"
    },
    "decomp": {
      "name": "R2_unt_disjoint_union_R2_D",
      "proof": [
        "v45: R2 = free-1 pairs not Type S with high\u2209H_M.",
        "Among non-S pairs: either Type D multipad side or untyped."
      ],
      "statement": "R2 = R2_unt \u2294 R2_D where R2_D = Type D multipad residual pairs (high\u2209H_M) and R2_unt = residual free-1 pairs that are not multi-core multipad sides (untyped single-core multi-U free-1).",
      "status": "PROVED"
    },
    "false_env": {
      "name": "HR2_small_envelopes_false",
      "statement": "On A_SP residual toys, all fail: |H_R2|\u2264\u230an/e\u230b, \u22642\u230an/e\u230b, \u2264pack_D\u00b7\u230an/e\u230b, and |H_R2|\u2264n (e.g. n=30, |H_R2|=952).",
