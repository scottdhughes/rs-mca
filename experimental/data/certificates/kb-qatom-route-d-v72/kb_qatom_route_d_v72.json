    },
    "diameter": {
      "name": "H_support_diameter_bound",
      "proof": [
        "Sum of s-1 gaps each <= e."
      ],
      "statement": "If supp(H) has s points and consecutive gaps <= e, then max(supp H)-min(supp H) <= e(s-1).",
      "status": "PROVED"
    },
    "full_shift": {
      "name": "full_support_shift_block",
      "proof": [
        "X^i multiplies degrees by +i; coefficients unchanged."
      ],
      "statement": "If P has all coeffs on 0..m nonzero, then X^i P has all coeffs on i..i+m nonzero.",
      "status": "PROVED"
    },
    "gap_product": {
      "name": "separated_monomials_product_support",
      "proof": [
        "Each h_j X^{i_j} P occupies full block [i_j, i_j+m].",
        "Gaps force blocks pairwise disjoint; each site hit once."
      ],
      "statement": "If P full support deg m and H=sum h_j X^{i_j} with i_{j+1}>=i_j+m+1, then supp(P H)=s(m+1) with s=#terms (no cancel).",
      "status": "PROVED"
    },
    "min_support": {
      "name": "min_support_multiple_deg_lt_n",
      "proof": [
        "Else supp G = t <= e with distinct a_j in 0..n-1 => distinct v_j=omega^{a_j}; vanishing is Vandermonde system of rank t on c_j.",
        "t<=e => only c=0. Minimum e+1 from c X^r P_e."
      ],
      "statement": "If G!=0, deg G < n=ord(omega), and G(omega^k)=0 for k=0..e-1, then supp(G) >= e+1.",
      "status": "PROVED"
    },
    "multipad_gap_law": {
      "name": "multipad_H_consecutive_gaps_le_e",
      "proof": [
        "If gap i_{j+1}-i_j >= e+1, split H=H_L+H_R.",
        "Product supports disjoint => supp(G)=supp(P H_L)+supp(P H_R).",
        "Each side nonzero, deg < n, P_e divides => supp >= e+1 each.",
        "Hence supp(G)>=2e+2 > 2e, contradiction."
      ],
      "statement": "For multipad G=P_e H with supp(G)=2e and deg G < n: every consecutive gap in supp(H) is at most e.",
      "status": "PROVED"
    }
  },
