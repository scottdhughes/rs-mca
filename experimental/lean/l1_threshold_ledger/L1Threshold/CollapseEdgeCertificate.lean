namespace L1Threshold

/-!
# W3 collapse-edge finite graph certificate

This file is generated from the finite certificate
`w3_collapse_edge_certificate_combo012_sizes10_2_3.json`.

Scope:

* finite graph rules only;
* no reconstruction of the underlying `GF(137)` arithmetic;
* no global L1 theorem.

The checker activates each stored edge rule at the certified seed shift,
validates the stored component decomposition, and proves that the alternate
contribution is at most `1` in all six dangerous `(missing,stray)=(2,1)` cases.
-/

namespace CollapseEdgeCertificate

set_option maxRecDepth 1000000
set_option maxHeartbeats 2000000

inductive EdgeKind where
  | always
  | never
  | atShift (t : Nat)
deriving Repr, DecidableEq, BEq

structure EdgeRule where
  a : Nat
  b : Nat
  kind : EdgeKind
deriving Repr, DecidableEq, BEq

structure CosetCert where
  cosetW : Nat
  points : List Nat
  edgeRules : List EdgeRule
  activeEdges : List (Nat × Nat)
  components : List (List Nat)
deriving Repr

structure LargeComponent where
  cosetW : Nat
  component : List Nat
deriving Repr, DecidableEq, BEq

structure CaseCert where
  caseIndex : Nat
  shift : Nat
  headMissing : Nat
  headStray : Nat
  headCoset : CosetCert
  alternateCosets : List CosetCert
  expectedAlternateLarge : List LargeComponent
deriving Repr

def rule (a b : Nat) (kind : EdgeKind) : EdgeRule := { a := a, b := b, kind := kind }

def edge (a b : Nat) : Nat × Nat := (a, b)

def contains (xs : List Nat) (x : Nat) : Bool :=
  xs.any (fun y => y == x)

def countNat (x : Nat) (xs : List Nat) : Nat :=
  xs.foldl (fun acc y => if y == x then acc + 1 else acc) 0

def flattenComponents (components : List (List Nat)) : List Nat :=
  components.foldr (fun comp acc => comp ++ acc) []

def addIfMissing (x : Nat) (xs : List Nat) : List Nat :=
  if contains xs x then xs else x :: xs

def activeRule (shift : Nat) (r : EdgeRule) : Bool :=
  match r.kind with
  | EdgeKind.always => true
  | EdgeKind.never => false
  | EdgeKind.atShift t => t == shift

def activeEdgesFromRules (shift : Nat) (rules : List EdgeRule) : List (Nat × Nat) :=
  rules.foldr (fun r acc => if activeRule shift r then edge r.a r.b :: acc else acc) []

def sameComponent (components : List (List Nat)) (a b : Nat) : Bool :=
  components.any (fun comp => contains comp a && contains comp b)

def countEdge (e : Nat × Nat) (edges : List (Nat × Nat)) : Nat :=
  edges.foldl (fun acc f => if f == e then acc + 1 else acc) 0

def edgeListsSame (xs ys : List (Nat × Nat)) : Bool :=
  xs.all (fun e => countEdge e ys == countEdge e xs)
    && ys.all (fun e => countEdge e xs == countEdge e ys)

def partitionOK (points : List Nat) (components : List (List Nat)) : Bool :=
  let flat := flattenComponents components
  points.all (fun p => countNat p flat == 1)
    && flat.all (fun p => contains points p)

def rulesUsePoints (points : List Nat) (rules : List EdgeRule) : Bool :=
  rules.all (fun r => contains points r.a && contains points r.b)

def stepClosure (component : List Nat) (edges : List (Nat × Nat)) (seen : List Nat) : List Nat :=
  edges.foldl
    (fun acc e =>
      let a := e.1
      let b := e.2
      if contains component a && contains component b then
        if contains acc a then addIfMissing b acc
        else if contains acc b then addIfMissing a acc
        else acc
      else acc)
    seen

def closure : Nat → List Nat → List (Nat × Nat) → List Nat → List Nat
  | 0, _, _, seen => seen
  | fuel + 1, component, edges, seen => closure fuel component edges (stepClosure component edges seen)

def connectedComponent (component : List Nat) (edges : List (Nat × Nat)) : Bool :=
  match component with
  | [] => true
  | root :: _ =>
      let seen := closure component.length component edges [root]
      component.all (fun p => contains seen p)

def componentsValid (shift : Nat) (cert : CosetCert) : Bool :=
  let active := activeEdgesFromRules shift cert.edgeRules
  edgeListsSame active cert.activeEdges
    && rulesUsePoints cert.points cert.edgeRules
    && partitionOK cert.points cert.components
    && cert.components.all (fun comp => connectedComponent comp active)
    && active.all (fun e => sameComponent cert.components e.1 e.2)

def componentContribution (component : List Nat) : Nat :=
  if 3 <= component.length then component.length - 2 else 0

def componentsContribution (components : List (List Nat)) : Nat :=
  components.foldl (fun acc comp => acc + componentContribution comp) 0

def largeComponents (components : List (List Nat)) : List (List Nat) :=
  components.filter (fun comp => decide (3 <= comp.length))

def alternateLarge (caseCert : CaseCert) : List LargeComponent :=
  caseCert.alternateCosets.foldr
    (fun coset acc =>
      (largeComponents coset.components).map
        (fun comp => { cosetW := coset.cosetW, component := comp })
      ++ acc)
    []

def alternateContribution (caseCert : CaseCert) : Nat :=
  caseCert.alternateCosets.foldl
    (fun acc coset => acc + componentsContribution coset.components)
    0

def checkCase (caseCert : CaseCert) : Bool :=
  componentsValid caseCert.shift caseCert.headCoset
    && caseCert.alternateCosets.all (fun coset => componentsValid caseCert.shift coset)
    && (caseCert.headMissing == 2)
    && (caseCert.headStray == 1)
    && (alternateLarge caseCert == caseCert.expectedAlternateLarge)
    && decide (alternateContribution caseCert <= 1)


